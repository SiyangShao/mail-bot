# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# LLM: DeepSeek is OpenAI-compatible. You can point these to another compatible provider.
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=3
LLM_JSON_MODE=true
LLM_USER_ID=mail-bot

# Gmail OAuth
GOOGLE_CREDENTIALS_PATH=/app/secrets/google_credentials.json
GOOGLE_TOKEN_PATH=/app/data/google_token.json
GMAIL_OAUTH_PORT=8080
GMAIL_POLL_SECONDS=120
GMAIL_BACKFILL_DAYS=2
GMAIL_QUERY=in:anywhere

# Storage/runtime
DATA_DIR=/app/data
SQLITE_PATH=/app/data/mail_bot.sqlite3
TZ=America/Los_Angeles
LOG_LEVEL=INFO
HASH_SALT=

# Notifications and summaries
DAILY_IMPORTANCE_MIN=3
DAILY_SUMMARY_TIME=09:00
DAILY_WINDOW_HOURS=24
MAX_EMAIL_CHARS_FOR_LLM=12000
MAX_DAILY_ITEMS=20
EMAIL_RETRY_MAX_ATTEMPTS=5
EMAIL_RETRY_BACKOFF_SECONDS=300
EMAIL_RETRY_MAX_BACKOFF_SECONDS=3600

# Event grouping (merge multiple emails about the same matter)
EVENT_WINDOW_DAYS=7
EVENT_MATCH_MAX_OPEN=12

# Event creation + priority mapping (importance 1-5 -> P0/P1/P2)
# imp >= P0_MIN -> P0 (Telegram alert); imp >= P1_MIN -> P1 (silent); else P2 (board only, no message).
# imp below EVENT_CREATE_IMPORTANCE_MIN never becomes an event.
EVENT_CREATE_IMPORTANCE_MIN=3
PRIORITY_P0_IMPORTANCE_MIN=5
PRIORITY_P1_IMPORTANCE_MIN=4
# Done events with no new email for this many days are auto-hidden from the board.
DONE_AUTO_HIDE_DAYS=30

# Web Kanban (mail-bot web). Required to run the web server.
WEB_PASSWORD=
# Random secret for signing session cookies, e.g. `openssl rand -hex 32`.
WEB_SESSION_SECRET=
WEB_PORT=8000
# How often (seconds) the live-board SSE stream samples the DB for changes. Default 3.
WEB_STREAM_POLL_SECONDS=3

# Cloudflare named tunnel token (from the Zero Trust dashboard).
CLOUDFLARE_TUNNEL_TOKEN=
# Optional in-app Cloudflare Access JWT verification (defense in depth).
# Fill both to enforce; leave empty to rely on Access at the edge only.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
